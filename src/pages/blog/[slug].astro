---
import PageLayout from "../../layouts/PageLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
	const posts = await getCollection("blog");
	return posts.map((post) => ({
		params: { slug: post.slug },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content } = await post.render();

const formattedDate = post.data.pubDate.toLocaleDateString('en-US', {
	month: 'long',
	day: 'numeric',
	year: 'numeric'
});
---

<PageLayout title={`${post.data.title} - Yash Kukreja`}>
	<article class="blog-post">
		<header class="blog-post__header">
			<div class="blog-post__meta">
				<span class={`blog-tag blog-tag--${post.data.tagClass?.replace('tag-', '') || 'general'}`}>
					{post.data.tag}
				</span>
				<span class="blog-post__date text-muted">
					<i class="fa-regular fa-calendar"></i> {formattedDate}
				</span>
				<span class="blog-post__read-time text-muted">
					<i class="fa-regular fa-clock"></i> {post.data.readTime}
				</span>
			</div>
			<h1 class="blog-post__title font-display">{post.data.title}</h1>
			{post.data.description && (
				<p class="blog-post__description text-muted">{post.data.description}</p>
			)}
		</header>

		<hr class="blog-post__divider" />

		<div class="blog-post__content prose">
			<Content />
		</div>

		<footer class="blog-post__footer">
			<a href="/blogs" class="blog-post__back">
				<i class="fa-solid fa-arrow-left"></i> Back to Feed
			</a>
		</footer>
	</article>
</PageLayout>

<style lang="scss">
	.blog-post {
		max-width: 800px;
		margin: 0 auto;
		padding: 40px 20px;

		&__header {
			margin-bottom: 40px;
		}

		&__meta {
			display: flex;
			align-items: center;
			gap: 16px;
			margin-bottom: 20px;
			font-size: 14px;
			flex-wrap: wrap;
		}

		&__title {
			font-size: 2.5rem;
			line-height: 1.2;
			margin-bottom: 16px;
			color: var(--color-text);

			@media (max-width: 768px) {
				font-size: 2rem;
			}
		}

		&__description {
			font-size: 1.25rem;
			line-height: 1.6;
			margin-bottom: 0;
		}

		&__divider {
			border: 0;
			border-top: 1px solid var(--color-border);
			margin: 40px 0;
		}

		&__content {
			font-size: 1.125rem;
			line-height: 1.8;
			color: var(--color-text);

			:global(h2) {
				font-size: 1.75rem;
				margin: 2rem 0 1rem;
				font-family: var(--font-display);
			}

			:global(p) {
				margin-bottom: 1.5rem;
			}

			:global(ul), :global(ol) {
				margin-bottom: 1.5rem;
				padding-left: 1.5rem;
			}

			:global(li) {
				margin-bottom: 0.5rem;
			}

			:global(code) {
				background: var(--color-card-hover);
				padding: 2px 4px;
				border-radius: 4px;
				font-size: 0.9em;
			}
		}

		&__footer {
			margin-top: 60px;
			padding-top: 30px;
			border-top: 1px solid var(--color-border);
		}

		&__back {
			display: inline-flex;
			align-items: center;
			gap: 8px;
			color: var(--color-primary);
			text-decoration: none;
			font-weight: 500;
			transition: gap 0.3s;

			&:hover {
				gap: 12px;
			}
		}
	}

	/* Tag styles are inherited from global.scss */
</style>

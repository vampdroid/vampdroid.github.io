---
import PageLayout from "../layouts/PageLayout.astro";
import { Icon } from "astro-icon/components";
---

<PageLayout title="404 - Page Not Found">
	<div class="error-page">
		<div class="error-page__content card">
			<div class="error-page__illustration">
				<div class="error-page__code font-display">404</div>
				<div class="error-page__circle"></div>
			</div>
			
			<h1 class="error-page__title font-display">Page Not Found</h1>
			<p class="error-page__message text-muted">
				The page you're looking for doesn't exist or has been moved.
			</p>
			
			<div class="error-page__actions">
				<a href="/" class="error-page__btn error-page__btn--primary">
					<Icon name="fa6-solid:house" /> Home
				</a>
				<button onclick="history.back()" class="error-page__btn error-page__btn--outline">
					<Icon name="fa6-solid:arrow-left" /> Back
				</button>
			</div>
		</div>

		<div class="error-page__suggestions card card--small">
			<h2 class="error-page__subtitle font-display">Quick Links</h2>
			<ul class="error-page__list">
				<li><a href="/tech-blogs" class="error-page__link"><Icon name="fa6-solid:newspaper" /> Tech Blogs</a></li>
				<li><a href="/daily-blogs" class="error-page__link"><Icon name="fa6-solid:pen-to-square" /> Daily Blogs</a></li>
				<li><a href="/chat" class="error-page__link"><Icon name="fa6-solid:robot" /> AI Chat</a></li>
				<li><a href="/projects" class="error-page__link"><Icon name="fa6-solid:folder" /> Projects</a></li>
			</ul>
		</div>
	</div>
</PageLayout>

<style lang="scss">
	.error-page {
		display: flex;
		flex-direction: column;
		gap: var(--spacing-lg);

		&__content {
			text-align: center;
			padding: var(--spacing-3xl) var(--spacing-xl);
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: var(--spacing-md);
		}

		&__illustration {
			position: relative;
			margin-bottom: var(--spacing-lg);
		}

		&__code {
			font-size: 6rem;
			font-weight: 800;
			line-height: 1;
			color: var(--color-primary);
			position: relative;
			z-index: 2;
		}

		&__circle {
			position: absolute;
			top: 50%;
			left: 50%;
			transform: translate(-50%, -50%);
			width: 150px;
			height: 150px;
			background: var(--color-primary);
			filter: blur(60px);
			opacity: 0.1;
			z-index: 1;
		}

		&__title {
			font-size: var(--font-size-2xl);
			font-weight: 700;
		}

		&__message {
			font-size: var(--font-size-base);
			max-width: 400px;
			margin-bottom: var(--spacing-lg);
		}

		&__actions {
			display: flex;
			gap: var(--spacing-md);
			justify-content: center;
		}

		&__btn {
			padding: 10px 20px;
			border-radius: var(--radius-md);
			font-weight: 600;
			font-size: var(--font-size-sm);
			cursor: pointer;
			display: inline-flex;
			align-items: center;
			gap: 8px;
			transition: var(--transition-base);
			border: 1px solid transparent;

			&--primary {
				background: var(--color-primary);
				color: var(--color-white);
				&:hover {
					opacity: 0.9;
					transform: translateY(-1px);
				}
			}

			&--outline {
				background: transparent;
				border-color: var(--color-border);
				color: var(--color-text);
				&:hover {
					background: var(--gray-100);
					transform: translateY(-1px);
					html.dark & {
						background: var(--gray-800);
					}
				}
			}
		}

		&__suggestions {
			display: flex;
			flex-direction: column;
			gap: var(--spacing-md);
		}

		&__subtitle {
			font-size: var(--font-size-lg);
			font-weight: 600;
		}

		&__list {
			list-style: none;
			display: flex;
			gap: var(--spacing-md);
			flex-wrap: wrap;
		}

		&__link {
			display: flex;
			align-items: center;
			gap: 8px;
			padding: 4px 12px;
			border-radius: var(--radius-full);
			background: var(--gray-100);
			font-size: var(--font-size-sm);
			font-weight: 500;
			transition: var(--transition-base);

			html.dark & {
				background: var(--gray-800);
			}

			&:hover {
				background: var(--color-primary);
				color: var(--color-white);
			}
		}
	}
</style>

---
import { Image } from 'astro:assets';
import { fetchYoutubeVideos } from '../../services/youtube';

interface Props {
	layout?: 'column' | 'grid';
	limit?: number;
}

const { layout = 'column', limit } = Astro.props;
let videos = await fetchYoutubeVideos();

if (limit) {
	videos = videos.slice(0, limit);
}
---
<div class={`youtube-videos youtube-videos--layout-${layout}`}>
	{videos.map((video: any) => (
		<a class="card card--small youtube-videos__item group" href={`https://youtube.com/watch?v=${video.id}`} target="_blank" rel="noopener noreferrer">
			<div class="youtube-videos__thumbnail-wrapper">
				<Image 
					src={video.thumbnail} 
					alt={video.title} 
					class="youtube-videos__thumbnail" 
					width={480} 
					height={270}
					loading="lazy"
				/>
				<div class="youtube-videos__overlay"></div>
			</div>
			<div class="youtube-videos__info">
				<h3 class="youtube-videos__title">{video.title}</h3>
				<p class="youtube-videos__meta">Video</p>
			</div>
		</a>
	))}
</div>

<style lang="scss">
	@use "./YoutubeVideos.scss";
</style>

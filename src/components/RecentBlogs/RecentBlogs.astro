---
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const posts = allPosts
  .sort((a, b) => new Date(b.data.pubDate).getTime() - new Date(a.data.pubDate).getTime())
  .slice(0, 3);

const formatDate = (date: any) => {
  return new Date(date).toLocaleDateString('en-US', {
    month: 'short',
    day: 'numeric',
    year: 'numeric'
  });
};
---

<div class='recent-blogs'>
	{posts && posts.length > 0 ? (
		posts.map((post) => (
			<a class="card recent-blogs__item group" href={`/blog/${post.slug}`}>
				<p class="recent-blogs__date">{formatDate(post.data.pubDate)}</p>
				<h3 class="font-display recent-blogs__title">{post.data.title}</h3>
				<div class="recent-blogs__excerpt text-muted">{post.data.description}</div>
				<div class="recent-blogs__read-more">
					Read Article <i class="fa-solid fa-arrow-right recent-blogs__icon-arrow"></i>
				</div>
			</a>
		))
	) : (
		<p class="text-muted">No blog posts available at the moment.</p>
	)}
</div>

<style lang="scss">
	@use "./RecentBlogs.scss";
</style>

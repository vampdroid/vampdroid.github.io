---
const { post } = Astro.props;

const imageUrl = post.data.image;

const formattedDate = post.data.pubDate.toLocaleDateString('en-US', {
	month: 'short',
	day: 'numeric',
	year: 'numeric'
});
---

<a href={`/tech-blogs/${post.slug || post.id}`} class="featured-blog-card-link">
	<article class={`card featured-blog-card ${!imageUrl ? 'featured-blog-card--no-image' : ''}`} data-category={post.data.tag?.toLowerCase()}>
		{imageUrl && (
			<div class="featured-blog-card__image-container">
				<img
					alt="Featured Post"
					class="featured-blog-card__image"
					src={imageUrl}
				/>
				<div class="featured-blog-card__overlay"></div>
			</div>
		)}
		<div class="featured-blog-card__content">
			<div class="blog-meta">
				<span class={`blog-tag blog-tag--${(post.data.tagClass || 'tag-uncategorized').replace('tag-', '')}`}>{post.data.tag}</span>
				<span class="blog-meta__read-time text-muted">
					<i class="fa-regular fa-clock"></i> {post.data.readTime}
				</span>
			</div>
			<h2 class="featured-blog-card__title font-display" transition:name={`title-${post.slug || post.id}`}>
				{post.data.title}
			</h2>
			<p class="featured-blog-card__description text-muted">
				{post.data.description}
			</p>
			<div class="featured-blog-card__footer">
				<span class="featured-blog-card__read-more">
					Read Full Story <i class="fa-solid fa-arrow-right"></i>
				</span>
				<span class="blog-meta__date text-muted">{formattedDate}</span>
			</div>
		</div>
	</article>
</a>

<style lang="scss">
	@use "./FeaturedBlogCard.scss";

	.featured-blog-card-link {
		text-decoration: none;
		color: inherit;
		display: block;
	}
</style>
